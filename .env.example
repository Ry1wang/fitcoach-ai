# Database
DATABASE_URL=postgresql+asyncpg://fitcoach:fitcoach_dev@postgres:5432/fitcoach
REDIS_URL=redis://redis:6379/0

# Auth
JWT_SECRET=your-secret-key-change-in-production

# LLM Provider (switch by changing these values — no code changes needed)
LLM_API_KEY=sk-xxxxxxxxxxxx
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_CHAT_MODEL=deepseek-chat

# Embedding Provider (optional — falls back to LLM_* if not set)
# EMBEDDING_API_KEY=sk-openai-xxx
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION=1536
EMBEDDING_MODEL=text-embedding-v1
EMBEDDING_DIMENSION=1024

# Rate limiter bypass list (optional) — JSON list of user UUIDs exempt
# from /chat per-minute rate limiting. Use ONLY for dedicated test users
# running regression sweeps. Leave empty in production.
# RATE_LIMIT_BYPASS_USER_IDS=["00000000-0000-0000-0000-000000000000"]

# Feishu/OpenClaw bot integration
BOT_API_KEY=fitcoach-bot-key-change-me
BOT_USER_ID=
